{
  "ConnectionStrings": {
    "DefaultConnection": "Host=<host>;Port=<port>;Database=<dbname>;Username=<username>;Password=<password>"
  },
  "OpenWeatherMap": {
    "ApiKey": "your-api-key-here",
    "BaseUrl": "https://api.openweathermap.org/data/3.0",
    "TimeoutSeconds": 15
  },
  "Jwt": {
    "Key": "super-secret-key-for-development-only-change-in-production",
    "Issuer": "weatherapi",
    "Audience": "weatherapi",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "AuthPermitLimit": 5,
    "AuthWindowMinutes": 1,
    "WeatherPermitLimit": 60,
    "WeatherWindowMinutes": 1
  },
  "Worker": {
    "RefreshIntervalMinutes": 60
  },
  "AllowedHosts": "*"
}
